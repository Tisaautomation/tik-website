---
import '../styles/global.css';

interface Props { title: string; description: string; }
const { title, description } = Astro.props;
const site = Astro.site?.toString() ?? 'https://tourinkohsamui.com/';
const canonical = new URL(Astro.url.pathname, site).toString();
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
// Self-hosted latin variable fonts, preloaded in <head>. font-display: swap so text
// paints immediately; preload + small latin-only files keep the font ready by LCP
// (kills the text-LCP delay and the font-swap CLS). Family names match the old
// fontsource @font-face, so global.css needs no change.
const fontCss = `@font-face{font-family:'Hanken Grotesk Variable';font-style:normal;font-weight:100 900;font-display:swap;src:url(${base}fonts/hanken-grotesk-latin-wght-normal.woff2) format('woff2-variations')}@font-face{font-family:'Fraunces Variable';font-style:normal;font-weight:100 900;font-display:swap;src:url(${base}fonts/fraunces-latin-wght-normal.woff2) format('woff2-variations')}`;
// Indexable on the real production build only (apex domain or explicit flag).
// GH Pages staging keeps noindex + robots Disallow so it stays hidden.
const indexable = process.env.TIK_INDEXABLE === '1' || site.startsWith('https://tourinkohsamui.com');

const organization = {
  '@context': 'https://schema.org',
  '@type': 'TravelAgency',
  name: 'Tour In Koh Samui',
  url: site,
  description: 'Local Koh Samui tour agency: boat trips, islands, adventures and ethical wildlife experiences booked direct with honest prices.',
  areaServed: 'Koh Samui, Thailand',
  sameAs: [
    'https://www.facebook.com/tourinkohsamui',
    'https://www.instagram.com/tourinkohsamui'
  ]
};
const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Tour In Koh Samui',
  url: site
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" href={`${base}fonts/hanken-grotesk-latin-wght-normal.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}fonts/fraunces-latin-wght-normal.woff2`} as="font" type="font/woff2" crossorigin />
    <style set:html={fontCss}></style>
    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#e7eaf0" />
    {!indexable && <meta name="robots" content="noindex, nofollow" />}
    {!indexable && <meta name="googlebot" content="noindex, nofollow" />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin />
    <script type="application/ld+json" set:html={JSON.stringify(organization)} />
    <script type="application/ld+json" set:html={JSON.stringify(website)} />
  </head>
  <body>
    <slot />
    <script is:inline set:html={`window.TIK_BASE=${JSON.stringify(base)}`}></script>
    <script src={`${base}currency.js`} defer></script>
    <script src={`${base}ui.js`} defer></script>
    <script src={`${base}chat.js`} defer></script>
  </body>
</html>
