---
import { Image } from 'astro:assets';
import logo from '../assets/tik-logo.png';
import compass from '../assets/tik-compass.png';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<footer class="site-footer" id="site-footer">
  <div class="wrap">
    <div class="footer-grid">
      <div class="footer-brand">
        <Image src={logo} alt="Tour In Koh Samui" width={240} class="footer-logo" loading="lazy" />
        <p class="footer-tag">The real Koh Samui. Hand-picked boat trips, islands and adventures, booked direct with the people who live it.</p>
        <div class="footer-social">
          <a href="https://www.facebook.com/tourinkohsamui" target="_blank" rel="noopener" aria-label="Facebook"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg></a>
          <a href="https://www.instagram.com/tourinkohsamui" target="_blank" rel="noopener" aria-label="Instagram"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="3.8"/><circle cx="17.4" cy="6.6" r="1.1" fill="currentColor" stroke="none"/></svg></a>
          <a href="https://www.tiktok.com/@tourinkohsamui.com" target="_blank" rel="noopener" aria-label="TikTok"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16.6 3c.25 2.07 1.46 3.36 3.4 3.55v2.4c-1.13.05-2.2-.23-3.4-.92v5.62c0 4.06-3.4 6.27-6.5 4.96-2.06-.88-2.94-3.06-2.32-5.06.62-2 2.6-3.16 4.82-2.74v2.55c-.34-.1-.7-.13-1.06-.06-.95.18-1.55 1-1.4 1.96.15.94 1.02 1.55 2 1.42.9-.12 1.46-.86 1.46-1.95V3h3z"/></svg></a>
          <a href="https://www.pinterest.com/tourinkohsamui" target="_blank" rel="noopener" aria-label="Pinterest"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-3.6 19.33c-.08-.82-.15-2.08.03-2.98l1.2-5.07s-.3-.6-.3-1.5c0-1.4.82-2.45 1.83-2.45.86 0 1.28.65 1.28 1.42 0 .87-.55 2.16-.84 3.36-.24 1 .5 1.82 1.5 1.82 1.8 0 3.18-1.9 3.18-4.64 0-2.42-1.74-4.12-4.23-4.12-2.88 0-4.57 2.16-4.57 4.4 0 .87.33 1.8.75 2.31.08.1.1.19.07.29l-.28 1.15c-.05.18-.15.22-.34.13-1.27-.59-2.06-2.45-2.06-3.94 0-3.21 2.33-6.16 6.72-6.16 3.53 0 6.27 2.51 6.27 5.87 0 3.5-2.21 6.32-5.28 6.32-1.03 0-2-.54-2.33-1.17l-.63 2.42c-.23.88-.85 1.98-1.27 2.65A10 10 0 1 0 12 2z"/></svg></a>
        </div>
      </div>
      <nav class="footer-col" aria-label="Explore">
        <h3>Explore</h3>
        <a href={`${base}all-tours/`}>All tours</a>
        <a href={`${base}reviews/`}>Reviews</a>
        <a href={`${base}#why`}>Why TIK</a>
        <a href={`${base}faq/`}>FAQ</a>
        <a href={`${base}blog/`}>Blog</a>
      </nav>
      <nav class="footer-col" aria-label="Company">
        <h3>Company</h3>
        <a href={`${base}#why`}>About us</a>
        <a href={`${base}blog/`}>Explore Koh Samui</a>
        <a href="mailto:info@tourinkohsamui.com">Contact</a>
        <a href={`${base}privacy/`}>Privacy Policy</a>
      </nav>
      <div class="footer-col">
        <h3>Get in touch</h3>
        <a href="mailto:info@tourinkohsamui.com">info@tourinkohsamui.com</a>
        <a href="https://wa.me/66613058528" target="_blank" rel="noopener">WhatsApp +66 61 305 8528</a>
        <span>Koh Samui, Thailand</span>
        <span>Open 06:00 to 00:00</span>
        <span class="footer-fine">Night bookings confirmed first thing in the morning.</span>
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-compass"><Image src={compass} alt="" width={120} loading="lazy" /> Tour In Koh Samui</span>
      <p class="footer-legal">© 2026 Tour In Koh Samui. All rights reserved. · <a href={`${base}privacy/`}>Privacy</a></p>
    </div>
  </div>
</footer>
