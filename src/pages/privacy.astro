---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import privacy from '../data/privacy.json';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://tik-website-designer.vercel.app/' },
    { '@type': 'ListItem', position: 2, name: 'Privacy Policy', item: 'https://tik-website-designer.vercel.app/privacy/' },
  ],
};
---
<Base
  title="Privacy Policy · Tour In Koh Samui"
  description="How Tour In Koh Samui collects, uses and protects your personal data when you book tours and transfers in Koh Samui, Thailand."
>
  <Header />
  <main id="main">
    <section class="page-hero">
      <div class="wrap">
        <nav class="crumbs" aria-label="Breadcrumb"><a href={import.meta.env.BASE_URL}>Home</a><span aria-hidden="true">/</span><span>Privacy Policy</span></nav>
        <p class="eyebrow">Legal</p>
        <h1>Privacy Policy</h1>
        <p class="lead">How we collect, use and protect your personal data when you book with Tour In Koh Samui.</p>
      </div>
    </section>

    <section style="padding-top:0">
      <div class="wrap">
        <div class="prose" set:html={privacy.html} />
      </div>
    </section>
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
</Base>
