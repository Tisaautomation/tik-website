---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TourCard from '../components/TourCard.astro';
import catalog from '../data/all-tours.json';
import activeHandles from '../data/active-handles.json';

// Show ONLY tours that are ACTIVE in Shopify. `active-handles.json` is regenerated
// at build time by `scripts/sync-active-status.mjs` (npm prebuild) from the live
// Shopify product status, so a draft/active flip is reflected on the next build.
// Fail-open: if the active list is empty (sync skipped/failed), show the full catalog.
const handleOf = (t) => t.url.split('/').pop();
const activeSet = new Set(activeHandles);
const tours = activeSet.size ? catalog.filter((t) => activeSet.has(handleOf(t))) : catalog;

// Real product photos, downloaded locally → optimized to WebP/AVIF by astro:assets.
const files = import.meta.glob('../assets/tours/*.{jpg,png}', { eager: true, import: 'default' });
const byTk = {};
for (const p in files) { const m = p.match(/(TK\d+)\./); if (m) byTk[m[1]] = files[p]; }

const cats = [
  { label: 'Island & Boat', tk: 'TK001' },
  { label: 'Snorkeling', tk: 'TK027' },
  { label: 'Nature & Wildlife', tk: 'TK046' },
  { label: 'Adventure', tk: 'TK054' },
  { label: 'Private & Sunset', tk: 'TK008' },
  { label: 'Culture & Nightlife', tk: 'TK043' },
];

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'All Koh Samui tours',
  numberOfItems: tours.length,
  itemListElement: tours.map((t, i) => ({
    '@type': 'ListItem', position: i + 1, name: t.name, url: t.url,
  })),
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://tourinkohsamui.com/' },
    { '@type': 'ListItem', position: 2, name: 'All Tours', item: 'https://tourinkohsamui.com/all-tours/' },
  ],
};
---
<Base
  title={`All Koh Samui Tours · ${tours.length} Boat Trips, Islands & Adventures (2026) · Tour In Koh Samui`}
  description="Browse all Koh Samui tours by local experts: boat trips, island day tours, snorkeling, ethical wildlife and adventures. Honest direct prices, free cancellation and hotel pickup."
>
  <Header />

  <main id="main">
  <!-- PAGE HERO + FILTER -->
  <section class="page-hero">
    <div class="wrap">
      <nav class="crumbs" aria-label="Breadcrumb"><a href={import.meta.env.BASE_URL}>Home</a><span aria-hidden="true">/</span><span>All tours</span></nav>
      <p class="eyebrow">Every experience</p>
      <h1>All Koh Samui tours</h1>
      <p class="lead">Every hand-picked experience we run, from speedboat island day trips to ethical wildlife and sunset cruises. Booked direct with honest prices, free cancellation and hotel pickup.</p>
      <div class="tour-search" role="search">
        <div class="kw-wrap">
          <svg class="kw-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input id="kw-search" class="kw-search" type="search" placeholder="Search tours: e.g. Pig Island, Angthong, elephant…" aria-label="Search tours by keyword" />
        </div>
        <button type="button" class="btn btn-primary" id="find-btn">Find my tour</button>
      </div>
      <div class="fbar" role="group" aria-label="Filter tours by category">
        <button class="fpill" data-filter="all" aria-current="true">All tours</button>
        {cats.filter((c) => tours.some((t) => t.cat === c.label)).map((c) => (
          <button class="fpill" data-filter={c.label}>{c.label}</button>
        ))}
      </div>
    </div>
  </section>

  <!-- TOURS GRID -->
  <section id="tours" class="tours-list" style="padding-top:0">
    <div class="wrap">
      <h2 class="sr-only">All Koh Samui tours and experiences</h2>
      <div class="grid-tours">
        {tours.map((tour) => <TourCard tour={tour} image={byTk[tour.tk]} />)}
      </div>
      <p class="no-match" hidden>No tours match that search. <button type="button" class="linkish" data-filter="all">Show all tours</button></p>
    </div>
  </section>
  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(itemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

  <script is:inline>
    // Filter-pill active state + empty-state message. The actual card filtering
    // (data-filter buttons, #kw-search, #find-btn) is wired globally by ui.js.
    (function () {
      function ready(fn) { document.readyState !== 'loading' ? fn() : document.addEventListener('DOMContentLoaded', fn); }
      ready(function () {
        var pills = document.querySelectorAll('.fbar .fpill');
        var note = document.querySelector('.no-match');
        function setActive(el) {
          pills.forEach(function (p) { p.removeAttribute('aria-current'); });
          if (el) el.setAttribute('aria-current', 'true');
        }
        function syncNote() {
          if (!note) return;
          var visible = [].filter.call(document.querySelectorAll('.card[data-cat]'), function (c) { return c.style.display !== 'none'; });
          note.hidden = visible.length > 0;
        }
        pills.forEach(function (p) { p.addEventListener('click', function () { setActive(p); setTimeout(syncNote, 0); }); });
        var kw = document.getElementById('kw-search');
        var find = document.getElementById('find-btn');
        var allPill = document.querySelector('.fbar .fpill[data-filter="all"]');
        // A keyword search spans every category, so highlight the "All tours" pill.
        if (kw) kw.addEventListener('keydown', function (e) { if (e.key === 'Enter') { setActive(allPill); setTimeout(syncNote, 0); } });
        if (find) find.addEventListener('click', function () { setActive(allPill); setTimeout(syncNote, 0); });
        document.querySelectorAll('.no-match [data-filter]').forEach(function (b) {
          b.addEventListener('click', function () { var all = document.querySelector('.fbar .fpill[data-filter="all"]'); setActive(all); if (kw) kw.value = ''; setTimeout(syncNote, 0); });
        });
      });
    })();
  </script>

  <style>
    /* After a search/filter, ui.js scrolls #tours into view; offset for the sticky header. */
    #tours { scroll-margin-top: 86px; }
    .page-hero { padding-block: clamp(26px, 4vw, 52px) clamp(20px, 3vw, 34px); }
    .crumbs { display: flex; gap: 8px; align-items: center; font-size: .82rem; font-weight: 600; color: var(--ink-soft); margin-bottom: 16px; }
    .crumbs a:hover { color: var(--ink); }
    .crumbs span[aria-hidden] { opacity: .5; }
    .page-hero h1 { margin: 12px 0 16px; }
    .page-hero .lead { max-width: 64ch; }
    .tour-search { display: flex; gap: 12px; max-width: 640px; margin-top: 26px; background: var(--bg); border-radius: var(--r-lg); padding: 12px; box-shadow: var(--nm-in); }
    .tour-search .kw-wrap { flex: 1; }
    .tour-search .btn { flex: none; }
    .fbar { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
    .fpill { display: inline-flex; align-items: center; gap: .5em; background: var(--bg); box-shadow: var(--nm-sm); border-radius: var(--pill); padding: .62em 1.15em; font-weight: 700; font-size: .9rem; color: var(--ink-soft); transition: box-shadow .15s ease, transform .15s ease, color .15s ease; }
    .fpill:hover { transform: translateY(-2px); color: var(--ink); }
    .fpill[aria-current="true"] { box-shadow: var(--nm-in-sm); color: var(--brand-deep); }
    .fcount { font-size: .76rem; font-weight: 800; opacity: .7; }
    .fpill[aria-current="true"] .fcount { opacity: 1; }
    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0; }
    .no-match { margin-top: 32px; color: var(--ink-soft); font-weight: 600; }
    .linkish { color: var(--brand-deep); font-weight: 700; text-decoration: underline; }
    @media (max-width: 560px) {
      .tour-search { flex-direction: column; }
      .tour-search .btn { width: 100%; }
    }
  </style>
</Base>
