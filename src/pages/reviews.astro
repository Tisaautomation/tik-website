---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import reviews from '../data/reviews.json';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://tourinkohsamui.com/' },
    { '@type': 'ListItem', position: 2, name: 'Reviews', item: 'https://tourinkohsamui.com/reviews/' },
  ],
};
const reviewLd = {
  '@context': 'https://schema.org',
  '@type': 'TravelAgency',
  name: 'Tour In Koh Samui',
  url: 'https://tourinkohsamui.com/',
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', bestRating: '5', reviewCount: '14' },
  review: reviews.map((r) => ({
    '@type': 'Review',
    reviewRating: { '@type': 'Rating', ratingValue: String(r.rating), bestRating: '5' },
    author: { '@type': 'Person', name: r.name },
    reviewBody: r.text,
  })),
};
const faqs = [
  { q: `Can I get a refund if I cancel my Koh Samui tour?`, a: `Yes, within the window. You get a full refund when you cancel at least 48 hours before your tour. Between 24 and 47 hours before, you're eligible for a 50% refund. Under 24 hours, or a no-show, is charged in full. If bad weather forces a cancellation, you choose between a reschedule or a full refund on anything prepaid. The official cutoff is 11:59 PM (GMT+7), two days before your tour date.` },
  { q: `Can I book now and pay cash on the day of the tour?`, a: `Yes, on most tours. With "Book Now, Pay Later" you reserve your spot today and settle the full amount in Thai Baht on the day, directly with the local operator, for bookings under ฿8,000. Full Moon Party transfers, ferries and transfers are the exception, those must be paid in full up front.` },
  { q: `Do your tours include hotel pickup and drop-off?`, a: `Most tours include hotel pickup and drop-off. Your exact pickup time is emailed the evening before your tour, it's set by the operator based on your location and the route. Staying in a villa on a steep hill a van can't reach? Pickup is arranged at the nearest accessible point, like a 7-Eleven or a resort entrance.` },
  { q: `What happens if it rains on the day of my boat tour?`, a: `A bit of rain is normal in Samui and usually doesn't stop a tour, trips run as long as the sea and roads are safe. Only if the Thai Navy or local authorities declare conditions dangerous (storms, high waves) is the tour cancelled, and then you choose between a reschedule or a full refund on any prepaid amount.` },
  { q: `How far in advance should I book a tour in Koh Samui?`, a: `We recommend 2 to 5 days ahead, especially in high season when spots fill fast. Most tours take bookings until 9:30 PM the night before, and some private tours and ATV trips can even fit same-day requests, just message us to check availability.` },
  { q: `Is the Angthong Marine Park entrance fee included?`, a: `No. The Angthong Marine Park fee (300 THB adults, 150 THB children) is a government fee paid in cash to the park rangers on the day. The same applies to Koh Tan and Koh Madsum. Always check the "What's NOT included" section on each tour page before booking.` },
  { q: `Are speedboat tours suitable for pregnant women or older travelers?`, a: `We don't recommend speedboats during pregnancy, the ride is rough and bumpy. For older travelers we suggest a sailing boat or large boat instead, they're far smoother and more stable. Kids are welcome on most tours and under-4s usually join free. Not sure what fits? Message us before booking.` },
  { q: `Do I need to bring my own snorkeling gear?`, a: `No, masks and snorkels are provided on every boat trip. You're welcome to bring your own for comfort or hygiene. Fins usually aren't provided, to protect the coral reefs, but can sometimes be rented at the pier.` },
  { q: `Is it cheaper to book direct instead of through a big booking site?`, a: `Booking direct cuts out the middleman, so prices stay honest with no platform mark-up. We also run a Best Price Guarantee: find the same tour cheaper elsewhere and we'll match it and take an extra 7% off (price proof at least 3 days before, and it doesn't apply to already-discounted tours).` },
  { q: `What's the difference between a private and a join-in tour?`, a: `A join-in (group) tour shares the boat with other guests on a fixed schedule, it's great value. A private tour is just your group: a base price per boat, your own start time, and an itinerary you can shape on the day. Private doesn't always mean a smaller boat, it means the boat is yours.` },
];
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---
<Base
  title="Reviews · Tour In Koh Samui · What Our Guests Say (Google & GetYourGuide)"
  description="Real reviews from guests who booked Koh Samui tours direct with Tour In Koh Samui. Google 4.9 and GetYourGuide 4.6 — honest prices, hotel pickup, free cancellation."
>
  <Header />
  <main id="main">
    <section class="page-hero">
      <div class="wrap">
        <nav class="crumbs" aria-label="Breadcrumb"><a href={import.meta.env.BASE_URL}>Home</a><span aria-hidden="true">/</span><span>Reviews</span></nav>
        <p class="eyebrow">Real guests, real trips</p>
        <h1>Reviews from our guests</h1>
        <p class="lead">What travellers say after booking Koh Samui tours direct with us, on Google and GetYourGuide. No middlemen, honest prices, hotel pickup.</p>
        <div class="rating-bar rating-bar--page">
          <span class="rating-bar__label">Trusted on Google &amp; GetYourGuide</span>
          <div class="rating-bar__chips">
            <a class="rbchip" href="https://g.page/r/Cc5apeTRAwypEBM/review" target="_blank" rel="noopener" aria-label="Google 4.9 stars, read our reviews">
              <svg class="rbchip__g" viewBox="0 0 272 92" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill="#EA4335" d="M115.75 47.18c0 12.77-9.99 22.18-22.25 22.18s-22.25-9.41-22.25-22.18C71.25 34.32 81.24 25 93.5 25s22.25 9.32 22.25 22.18zm-9.74 0c0-7.98-5.79-13.44-12.51-13.44S80.99 39.2 80.99 47.18c0 7.9 5.79 13.44 12.51 13.44s12.51-5.55 12.51-13.44z"/><path fill="#FBBC05" d="M163.75 47.18c0 12.77-9.99 22.18-22.25 22.18s-22.25-9.41-22.25-22.18c0-12.85 9.99-22.18 22.25-22.18s22.25 9.32 22.25 22.18zm-9.74 0c0-7.98-5.79-13.44-12.51-13.44s-12.51 5.46-12.51 13.44c0 7.9 5.79 13.44 12.51 13.44s12.51-5.55 12.51-13.44z"/><path fill="#4285F4" d="M209.75 26.34v39.82c0 16.38-9.66 23.07-21.08 23.07-10.75 0-17.22-7.19-19.66-13.07l8.48-3.53c1.51 3.61 5.21 7.87 11.17 7.87 7.31 0 11.84-4.51 11.84-13v-3.19h-.34c-2.18 2.69-6.38 5.04-11.68 5.04-11.09 0-21.25-9.66-21.25-22.09 0-12.52 10.16-22.26 21.25-22.26 5.29 0 9.49 2.35 11.68 4.96h.34v-3.61h9.25zm-8.56 20.92c0-7.81-5.21-13.52-11.84-13.52-6.72 0-12.35 5.71-12.35 13.52 0 7.73 5.63 13.36 12.35 13.36 6.63 0 11.84-5.63 11.84-13.36z"/><path fill="#34A853" d="M225 3v65h-9.5V3h9.5z"/><path fill="#EA4335" d="M262.02 54.48l7.56 5.04c-2.44 3.61-8.32 9.83-18.48 9.83-12.6 0-22.01-9.74-22.01-22.18 0-13.19 9.49-22.18 20.92-22.18 11.51 0 17.14 9.16 18.98 14.11l1.01 2.52-29.65 12.28c2.27 4.45 5.8 6.72 10.75 6.72 4.96 0 8.4-2.44 10.92-6.14zm-23.27-7.98l19.82-8.23c-1.09-2.77-4.37-4.7-8.23-4.7-4.95 0-11.84 4.37-11.59 12.93z"/><path fill="#4285F4" d="M35.29 41.41V32H67c.31 1.64.47 3.58.47 5.68 0 7.06-1.93 15.79-8.15 22.01-6.05 6.3-13.78 9.66-24.02 9.66C16.32 69.35.36 53.89.36 34.91.36 15.93 16.32.47 35.3.47c10.5 0 17.98 4.12 23.6 9.49l-6.64 6.64c-4.03-3.78-9.49-6.72-16.97-6.72-13.86 0-24.7 11.17-24.7 25.03 0 13.86 10.84 25.03 24.7 25.03 8.99 0 14.11-3.61 17.39-6.89 2.66-2.66 4.41-6.46 5.1-11.65l-22.49.01z"/></svg>
              <span class="rbchip__rating">4.9<span class="rbchip__star" aria-hidden="true">★</span></span>
            </a>
            <a class="rbchip" href="https://www.getyourguide.com/tik-tourinkohsamui-s733825/" target="_blank" rel="noopener" aria-label="getyourguide 4.6 stars, read our reviews">
              <span class="rbchip__gyg">getyourguide</span>
              <span class="rbchip__rating">4.6<span class="rbchip__star" aria-hidden="true">★</span></span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section style="padding-top:0">
      <div class="wrap">
        <div class="reviews-all">
          {reviews.map((r) => (
            <figure class="review">
              <div class="stars">{'★'.repeat(r.rating)}</div>
              <p>“{r.text}”</p>
              <figcaption class="who">{r.name}<small>{[r.country, r.source].filter(Boolean).join(' · ')}</small></figcaption>
            </figure>
          ))}
        </div>
        <p class="reviews-more">More reviews on <a href="https://g.page/r/Cc5apeTRAwypEBM/review" target="_blank" rel="noopener">Google</a> and <a href="https://www.getyourguide.com/tik-tourinkohsamui-s733825/" target="_blank" rel="noopener">GetYourGuide</a>.</p>
      </div>
    </section>

    <section style="padding-top:0">
      <div class="wrap">
        <h2 class="faq-h2">Questions guests ask before booking</h2>
        <div class="faq">
          {faqs.map((f) => (
            <details open>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(reviewLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />

  <style>
    .rating-bar--page { border-top: none; border-radius: var(--r-lg); box-shadow: var(--nm); margin-top: clamp(20px, 3vw, 32px); }
    .reviews-all { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: clamp(16px, 2.4vw, 24px); align-items: start; }
    .reviews-all .review { height: 100%; }
    .reviews-more { margin-top: clamp(24px, 3vw, 36px); color: var(--ink-soft); font-weight: 600; }
    .reviews-more a { color: var(--brand-deep); }
  </style>
</Base>
