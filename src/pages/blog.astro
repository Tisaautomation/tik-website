---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import posts from '../data/blog.json';

const fmtDate = (d) => new Date(d + 'T00:00:00Z').toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', timeZone: 'UTC' });
const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Explore Koh Samui, the Tour In Koh Samui blog',
  numberOfItems: posts.length,
  itemListElement: posts.map((p, i) => ({ '@type': 'ListItem', position: i + 1, name: p.title, url: p.url })),
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://tik-website-designer.vercel.app/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://tik-website-designer.vercel.app/blog/' },
  ],
};
---
<Base
  title="Explore Koh Samui · The Tour In Koh Samui Blog · Local Guides & Tips"
  description="Local guides, tips and stories for Koh Samui: the best island day trips, snorkeling spots, the Full Moon Party, ethical wildlife and how to plan your trip like a local."
>
  <Header />
  <main id="main">
    <section class="page-hero">
      <div class="wrap">
        <nav class="crumbs" aria-label="Breadcrumb"><a href="/">Home</a><span aria-hidden="true">/</span><span>Blog</span></nav>
        <p class="eyebrow">Explore Koh Samui</p>
        <h1>Guides and stories from the island</h1>
        <p class="lead">Local tips on the best day trips, snorkeling, the Full Moon Party and how to plan your Koh Samui trip like someone who lives here.</p>
      </div>
    </section>

    <section style="padding-top:0">
      <div class="wrap">
        <h2 class="sr-only">All blog articles</h2>
        <div class="blog-grid">
          {posts.map((p) => (
            <a class="blog-card" href={p.url}>
              <div class="ph"><img src={p.img} alt={p.title} width="700" height="438" loading="lazy" decoding="async" /></div>
              <div class="body">
                <time datetime={p.date}>{fmtDate(p.date)}</time>
                <h2>{p.title}</h2>
                {p.summary && <p>{p.summary}</p>}
                <span class="more">Read more</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(itemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
</Base>
